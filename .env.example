# Database (Supabase pooler for app connections, direct for migrations)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# JWT — generate with: openssl rand -base64 64
JWT_SECRET="REPLACE_WITH_SECURE_RANDOM_SECRET"

# Supabase
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_JWT_SECRET="REPLACE_WITH_SUPABASE_JWT_SECRET"
SUPABASE_SERVICE_ROLE_KEY="REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY"

# CORS — allowed origins for SaaS dashboard and marketing website
FRONTEND_URL="https://app.usetams.com"
WEBSITE_URL="https://usetams.com"

# Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_GROWTH_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."

# Server
PORT=3002
